{
  "name": "@stonly/design-system",
  "version": "1.0.0",
  "description": "Stonly Design System - shared UI components and design tokens",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@bitbucket.org/stonlybucket/stonly-design-system.git"
  },
  "homepage": "https://bitbucket.org/stonlybucket/stonly-design-system#readme",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./icons/*": {
      "import": "./dist/esm/ui/atoms/icons/*.js",
      "require": "./dist/cjs/ui/atoms/icons/*.cjs"
    },
    "./providers": {
      "import": "./dist/esm/ui/providers/index.js",
      "require": "./dist/cjs/ui/providers/index.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "AGENT.md",
    "CLAUDE.md",
    "README.md"
  ],
  "peerDependencies": {
    "react": "^16.10.2",
    "react-dom": "^16.10.2",
    "styled-components": "^6.1.19"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.0.1",
    "date-fns": "^2.24.0",
    "framer-motion": "3.2.1",
    "lodash": "^4.17.21",
    "react-textarea-autosize": "^8.5.3",
    "stylis": "^4.3.6",
    "stylis-plugin-rtl": "^2.1.1",
    "tabbable": "^6.2.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.6.4",
    "@rsbuild/core": "^1.1.0",
    "@rsbuild/plugin-react": "^1.1.0",
    "@rsbuild/plugin-svgr": "^1.1.0",
    "@rslib/core": "^0.19.6",
    "@storybook/addon-designs": "^8.0.0",
    "@storybook/addon-docs": "^8.0.0",
    "@storybook/addon-links": "^8.0.0",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.1.2",
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^12.8.3",
    "@types/jest": "^29.5.4",
    "@types/node": "^14.14.12",
    "@types/react": "^16.0.0",
    "@types/react-dom": "^16.0.0",
    "@types/react-svg": "^5.0.0",
    "@types/stylis": "^4",
    "husky": "^9.1.7",
    "jest": "^29.6.4",
    "jest-environment-jsdom": "^29.6.4",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "storybook": "^8.0.0",
    "storybook-react-rsbuild": "^0.1.0",
    "styled-components": "^6.3.11",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2",
    "url-loader": "^2.0.0"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "test": "jest --bail",
    "storybook": "storybook dev -p 9009",
    "build-storybook": "storybook build",
    "generate-agent-md": "node scripts/generate-agent-md.js",
    "prepublishOnly": "npm run generate-agent-md",
    "prepare": "husky"
  }
}
